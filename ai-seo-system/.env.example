# Environment variables for AI SEO Content System
# Copy this file to .env and fill in the values

# AI API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=gpt-4o-mini

# Site Configuration
SITE_URL=https://yourdomain.com
SITE_NAME=AI SEO Content System
SITE_DESCRIPTION=Automated SEO content generation and management system

# Git Configuration
GIT_REPO=git@github.com:username/repo.git
GIT_BRANCH=main
GIT_USER_NAME=AI SEO Bot
GIT_USER_EMAIL=seo-bot@yourdomain.com

# Content Settings
CONTENT_LANGUAGE=en
CONTENT_LOCALE=en_US
DEFAULT_AUTHOR=AI SEO Bot
DEFAULT_CATEGORY=Technology

# SEO Settings
DEFAULT_META_DESCRIPTION=AI-powered SEO content and automation
DEFAULT_TAGS=ai,seo,content,automation

# Scheduling Settings
DAILY_UPDATE_HOUR=2
DAILY_KEYWORD_REFRESH_DAYS=7
DAILY_CONTENT_GENERATION_LIMIT=3

# Safety and Quality
MIN_WORD_COUNT=800
MAX_KEYWORD_DENSITY=2.5
MAX_LINK_DENSITY=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/ai-seo-system.log

# Monitoring
SLACK_WEBHOOK_URL=your_slack_webhook_here
ENABLE_METRICS=true
METRICS_INTERVAL=3600

# Database (optional)
DATABASE_URL=sqlite:///data/ai-seo-system.db

# External Services
GOOGLE_SEARCH_API_KEY=your_google_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id
